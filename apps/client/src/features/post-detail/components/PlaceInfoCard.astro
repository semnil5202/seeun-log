---
/** 장소 정보 카드. Schema.org LocalBusiness 마크업을 포함한다. */

import type { Locale } from "@/shared/types/common";
import { t } from "@/shared/lib/i18n/translations";

interface Props {
  categoryLabel: string;
  subCategoryLabel: string;
  placeName: string;
  translatedPlaceName?: string | null;
  address: string;
  translatedAddress?: string | null;
  pricePrefix?: string | null;
  price: number | null;
  description: string;
  translatedDescription?: string | null;
  locale: Locale;
}

const {
  categoryLabel,
  subCategoryLabel,
  placeName,
  translatedPlaceName,
  address,
  translatedAddress,
  pricePrefix,
  price,
  description,
  translatedDescription,
  locale,
} = Astro.props;

const currencyUnit = t("place.currency", locale);
const priceLabel = price != null
  ? `${pricePrefix ?? ''}${price.toLocaleString()}${currencyUnit}`
  : null;
const targetCurrency = t("place.targetCurrency", locale);
const exchangeUrl = price != null && targetCurrency
  ? `https://www.google.com/search?q=${price}+KRW+to+${targetCurrency}`
  : null;
const mapUrl = locale === 'ko'
  ? `https://map.naver.com/v5/search/${encodeURIComponent(placeName)}`
  : `https://www.google.com/maps/search/${encodeURIComponent(placeName)}`;

const summaryLabel = t("post.summary", locale);
const summaryText = translatedDescription ?? description;
const summaryLines = summaryText ? summaryText.split('\n').filter(Boolean) : [];
const copyToast = locale !== 'ko' ? t("place.copyToast", locale) : undefined;
---

<div
  class="bg-gray-50 border border-gray-200 p-5 mb-6"
  itemscope
  itemtype="https://schema.org/LocalBusiness"
>
  <dl class="space-y-3 text-sm">
    <div class="flex items-baseline gap-3">
      <dt class="shrink-0 w-20 text-gray-500 font-medium">{t("place.category", locale)}</dt>
      <dd class="text-gray-900">{categoryLabel} <span class="text-base leading-none">›</span> {subCategoryLabel}</dd>
    </div>
    <div class="flex items-baseline gap-3">
      <dt class="shrink-0 w-20 text-gray-500 font-medium">{t("place.name", locale)}</dt>
      <dd class="flex items-baseline gap-1.5">
        <span class="text-gray-900 font-semibold" itemprop="name">
          {translatedPlaceName ?? placeName}
        </span>
        <a
          href={mapUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 translate-y-px text-gray-400 hover:text-gray-600 transition-colors"
          aria-label={t("a11y.mapSearch", locale)}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <title>{t("a11y.mapSearch", locale)}</title>
            <desc>{t("a11y.mapSearch", locale)}</desc>
            <path d="M7 7h10v10"></path>
            <path d="M7 17 17 7"></path>
          </svg>
        </a>
      </dd>
    </div>
    {address && (
      <div class="flex items-baseline gap-3">
        <dt class="shrink-0 w-20 text-gray-500 font-medium">{t("place.address", locale)}</dt>
        <dd class="flex items-baseline gap-1.5">
          <span class="text-gray-900" itemprop="address">{translatedAddress ?? address}</span>
          <button
            type="button"
            class="shrink-0 translate-y-px text-gray-400 hover:text-gray-600 transition-colors cursor-pointer"
            data-copy={address}
            data-toast={copyToast}
            aria-label={`${t("place.address", locale)} ${t("a11y.copy", locale)}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <title>{t("a11y.copy", locale)}</title>
              <desc>{`${t("place.address", locale)} ${t("a11y.copy", locale)}`}</desc>
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
        </dd>
      </div>
    )}
    {priceLabel && (
      <div class="flex items-baseline gap-3">
        <dt class="shrink-0 w-20 text-gray-500 font-medium">{t("place.price", locale)}</dt>
        <dd class="flex items-baseline gap-1.5">
          <span class="text-gray-900">{priceLabel}</span>
          {exchangeUrl && (
            <a
              href={exchangeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 translate-y-px text-gray-400 hover:text-gray-600 transition-colors"
              aria-label={t("a11y.currencyConverter", locale)}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <title>{t("a11y.currencyConverter", locale)}</title>
                <desc>{t("a11y.currencyConverter", locale)}</desc>
                <path d="M7 7h10v10"></path>
                <path d="M7 17 17 7"></path>
              </svg>
            </a>
          )}
        </dd>
      </div>
    )}
    {summaryLines.length > 0 && (
      <div class="flex items-baseline gap-3">
        <dt class="shrink-0 w-20 text-gray-500 font-medium">{summaryLabel}</dt>
        <dd class="text-gray-900">
          <ul class="space-y-0.5">
            {summaryLines.map((line) => (
              <li>⋅ {line}</li>
            ))}
          </ul>
        </dd>
      </div>
    )}
  </dl>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      await navigator.clipboard.writeText(text);
      const svg = btn.querySelector('svg')!;
      const original = svg.innerHTML;
      svg.innerHTML = '<polyline points="20 6 9 17 4 12"></polyline>';
      setTimeout(() => { svg.innerHTML = original; }, 1500);
    });
  });
</script>
