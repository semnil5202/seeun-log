---
/** 포스트 상세의 추천 뱃지 조합. */

import SponsoredBadge from "@/shared/components/ui/SponsoredBadge.astro";

interface Props {
  isRecommended: boolean;
  label: string;
}

const { isRecommended, label } = Astro.props;
---

{isRecommended && (
  <div class="flex gap-2 mb-3">
    <SponsoredBadge label={label} />
  </div>
)}
