---
/** 포스트 피드를 단일 컬럼 리스트로 렌더링한다. 2번째, 5번째 슬롯에 인피드 광고 삽입. */
import type { LocalizedPost } from "@/shared/types/post";
import type { Locale } from "@/shared/types/common";
import PostCard from "./PostCard.astro";
import SponsoredCard from "./SponsoredCard.astro";
import PostCardSkeleton from "./PostCardSkeleton.astro";
import InFeedAdsense from "@/shared/components/ad/InFeedAdsense.astro";

interface Props {
  posts: LocalizedPost[];
  locale: Locale;
  feedEndpoint?: string;
  hasNextPage?: boolean;
  sponsoredLabel?: string;
}

const { posts, locale, feedEndpoint, hasNextPage = false, sponsoredLabel = "" } = Astro.props;

type FeedItem =
  | { type: "post"; post: LocalizedPost; cardIndex: number }
  | { type: "ad"; adIndex: number };

const feedItems: FeedItem[] = [];
let cardIndex = 0;
let adIndex = 0;

for (let i = 0; i < posts.length; i++) {
  if (cardIndex === 1 || cardIndex === 3) {
    adIndex++;
    feedItems.push({ type: "ad", adIndex });
  }

  feedItems.push({ type: "post", post: posts[i]!, cardIndex });
  cardIndex++;
}
---

<div
  id="post-feed"
  class="flex flex-col gap-10"
  data-feed-endpoint={feedEndpoint}
  data-next-page="2"
  data-has-next={String(hasNextPage)}
  data-sponsored-label={sponsoredLabel}
>
  {feedItems.map((item) => {
    if (item.type === "ad") {
      // TODO: 애드센스 되돌리기 — <InFeedAdsense class="max-w-[640px] lg:max-w-none aspect-7/3" slotId={`in_feed_${item.adIndex}`} position={`feed_index_${item.adIndex}`} />
      return null;
    }

    if (item.post.is_recommended) {
      return (
        <SponsoredCard
          post={item.post}
          locale={locale}
          index={item.cardIndex}
        />
      );
    }

    return (
      <PostCard
        post={item.post}
        locale={locale}
        index={item.cardIndex}
        sponsoredLabel={sponsoredLabel}
      />
    );
  })}
</div>

{feedEndpoint && (
  <div id="feed-sentinel" class="h-1" />
)}

{feedEndpoint && (
  <script>
    const feed = document.getElementById("post-feed");
    const sentinel = document.getElementById("feed-sentinel");

    if (feed && sentinel) {
      const endpoint = feed.dataset.feedEndpoint!;
      let nextPage = parseInt(feed.dataset.nextPage!, 10);
      let hasNext = feed.dataset.hasNext === "true";
      let loading = false;
      let dynamicAdCounter = 2;
      const sponsoredLabel = feed.dataset.sponsoredLabel || "";

      const createAdSlot = (): HTMLDivElement => {
        dynamicAdCounter++;
        const wrapper = document.createElement("div");
        wrapper.className = "w-full max-w-[640px] lg:max-w-none aspect-7/3 bg-gray-100 flex items-center justify-center";
        wrapper.setAttribute("role", "complementary");
        wrapper.setAttribute("aria-label", "Advertisement");
        wrapper.dataset.adSlot = `in_feed_${dynamicAdCounter}`;
        wrapper.dataset.adFormat = "in_feed";
        wrapper.dataset.adPosition = `feed_index_${dynamicAdCounter}`;
        const span = document.createElement("span");
        span.className = "text-body2 text-gray-400 select-none";
        span.textContent = "In-feed Adsense";
        wrapper.appendChild(span);
        return wrapper;
      };

      const createPostCard = (post: any): HTMLElement => {
        const article = document.createElement("article");
        article.className = "group";
        article.dataset.postSlug = post.slug;
        article.dataset.postCategory = post.category;
        article.dataset.postSubCategory = post.subCategory;
        article.dataset.postSponsored = String(post.isSponsored);

        const showBadge = post.isRecommended;

        let badgeHtml = "";
        if (showBadge) {
          badgeHtml = `<span class="absolute top-3 left-3 inline-flex items-center text-xs font-semibold bg-primary-600 text-white rounded-md px-2.5 py-0.5">${sponsoredLabel}</span>`;
        }

        const placeHtml = post.placeName
          ? `<span aria-hidden="true">&middot;</span><span>${post.placeName}</span>`
          : "";

        article.innerHTML = `
          <a href="${post.href}" class="block">
            <div class="${showBadge ? "relative " : ""}w-full aspect-7/3 overflow-hidden bg-gray-100">
              <img
                src="${post.thumbnail}"
                alt="${post.title}"
                width="640"
                height="180"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
                decoding="async"
              />
              ${badgeHtml}
            </div>
            <div class="mt-4 flex flex-col gap-2">
              <h2 class="text-title2 font-bold text-gray-900 line-clamp-2 group-hover:text-primary-600 transition-colors">
                ${post.title}
              </h2>
              <p class="text-body2 text-gray-500 line-clamp-2">${post.description}</p>
              <div class="flex items-center gap-1.5 text-caption1 text-gray-400">
                <time>${post.dateStr}</time>
                ${placeHtml}
                <span aria-hidden="true">&middot;</span>
                <span>${post.categoryLabel}</span>
              </div>
            </div>
          </a>
        `;

        return article;
      };

      const loadNextPage = async () => {
        if (loading || !hasNext) return;
        loading = true;

        try {
          const res = await fetch(`${endpoint}${nextPage}.json`);
          if (!res.ok) {
            hasNext = false;
            sentinel.remove();
            return;
          }

          const data = await res.json();
          const posts: any[] = data.posts;
          hasNext = data.hasNext;

          let localIndex = 0;
          for (const post of posts) {
            if (localIndex === 1 || localIndex === 3) {
              const adSlot = createAdSlot();
              feed.appendChild(adSlot);
              if ((window as any).__observeNewAdSlot) {
                (window as any).__observeNewAdSlot(adSlot);
              }
            }
            feed.appendChild(createPostCard(post));
            localIndex++;
          }

          nextPage++;

          if (!hasNext) {
            sentinel.remove();
          }
        } catch {
          hasNext = false;
          sentinel.remove();
        } finally {
          loading = false;
        }
      };

      if (hasNext) {
        const observer = new IntersectionObserver(
          (entries) => {
            if (entries[0]?.isIntersecting) {
              loadNextPage();
            }
          },
          { rootMargin: "200px" },
        );
        observer.observe(sentinel);
      } else {
        sentinel.remove();
      }
    }
  </script>
)}

<script>
  import { initPostClickTracker } from "@/shared/lib/analytics/post-tracker";
  import { initAdTracker, observeNewAdSlot } from "@/shared/lib/analytics/ad-tracker";
  initPostClickTracker("post-feed");
  initAdTracker("list");
  (window as any).__observeNewAdSlot = observeNewAdSlot;

  const feed = document.getElementById("post-feed");
  const sentinel = document.getElementById("feed-sentinel");

  const skeletonCard = `<div class="animate-pulse max-w-[640px] max-h-[404px] lg:max-w-none lg:max-h-none"><div class="w-full aspect-7/3 bg-gray-200"></div><div class="mt-4 flex flex-col gap-2"><div class="h-5 bg-gray-200 rounded w-3/4"></div><div class="h-4 bg-gray-200 rounded w-full"></div><div class="h-4 bg-gray-200 rounded w-2/3"></div><div class="flex items-center gap-1.5"><div class="h-3 bg-gray-200 rounded w-20"></div><div class="h-3 bg-gray-200 rounded w-16"></div><div class="h-3 bg-gray-200 rounded w-12"></div></div></div></div>`;

  if (feed) {
    document.addEventListener("click", (e) => {
      const link = (e.target as HTMLElement).closest<HTMLAnchorElement>(
        "nav a[href]"
      );
      if (!link || link.getAttribute("aria-current")) return;

      e.preventDefault();
      if (sentinel) sentinel.classList.add("hidden");
      feed.style.width = `${feed.offsetWidth}px`;
      feed.innerHTML = skeletonCard + skeletonCard + skeletonCard;
      window.location.href = link.href;
    });
  }
</script>
