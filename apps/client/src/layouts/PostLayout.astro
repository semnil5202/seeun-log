---
/** 포스트 상세 레이아웃. 메인 피드와 동일한 3-column 구조. */

import Layout from "@/layouts/Layout.astro";
import LeftSidebar from "@/shared/components/layout/LeftSidebar.astro";
import RightSidebar from "@/shared/components/layout/RightSidebar.astro";
import BreadcrumbJsonLd from "@/shared/components/seo/BreadcrumbJsonLd.astro";
import BlogPostingJsonLd from "@/shared/components/seo/BlogPostingJsonLd.astro";
import SponsoredPostList from "@/shared/components/layout/SponsoredPostList.astro";
import FixedAdsense from "@/shared/components/ad/FixedAdsense.astro";
import PostBadges from "@/features/post-detail/components/PostBadges.astro";
import PlaceInfoCard from "@/features/post-detail/components/PlaceInfoCard.astro";
import ProductInfoCard from "@/features/post-detail/components/ProductInfoCard.astro";
import NearbyPostList from "@/features/post-detail/components/NearbyPostList.astro";
import { getSponsoredPosts, getMultilingualSponsoredPosts, getPostsBySubCategory } from "@/features/post-feed/api/posts";
import { DEFAULT_LOCALE } from "@/shared/types/common";
import { getLocalizedPost } from "@/features/post-feed/api/translations";
import { getLocalePath } from "@/shared/lib/i18n/locales";
import { t } from "@/shared/lib/i18n/translations";
import { formatDate } from "@/shared/lib/date";
import { insertInArticleAds } from "@/features/post-detail/lib/ads";
import { buildBlogPostingSchema } from "@/features/post-detail/lib/schema";
import { optimizedUrl, injectOptimizedUrls, injectZoomIcons } from "@/shared/lib/image";
import { injectLocalizedBookmarks } from "@/shared/lib/bookmark";
import type { LocalizedPost } from "@/shared/types/post";
import type { Locale } from "@/shared/types/common";
import type { BreadcrumbItem } from "@/shared/types/seo";

interface Props {
  post: LocalizedPost;
  locale: Locale;
  breadcrumbs: BreadcrumbItem[];
  canonical: string;
  path: string;
  categoryLabel: string;
  subCategoryLabel: string;
}

const { post, locale, breadcrumbs, canonical, path, categoryLabel, subCategoryLabel } = Astro.props;

const fetchSponsored = locale === DEFAULT_LOCALE
  ? getSponsoredPosts(post.category, post.sub_category)
  : getMultilingualSponsoredPosts(post.category, post.sub_category);

const [sponsoredRaw, subCategoryPosts] = await Promise.all([
  fetchSponsored,
  getPostsBySubCategory(post.category, post.sub_category),
]);
const sponsoredLocalized = await Promise.all(
  sponsoredRaw.map((p) => getLocalizedPost(p, locale)),
);

const currentIdx = subCategoryPosts.findIndex((p) => p.slug === post.slug);
const sliceStart = Math.max(0, currentIdx - 2);
const sliceEnd = Math.min(subCategoryPosts.length, currentIdx + 3);
const nearbyPosts = subCategoryPosts.slice(sliceStart, sliceEnd);
const nearbyLocalized = await Promise.all(
  nearbyPosts.map((p) => getLocalizedPost(p, locale)),
);

const subCategoryHref = getLocalePath(`/${post.category}/${post.sub_category}/`, locale);
const publishDate = formatDate(post.created_at, locale);
// TODO: 애드센스 되돌리기 — insertInArticleAds(post.content)
const contentWithAlts = post.image_alts?.length
  ? post.image_alts.reduce(
      (html, { src, alt }) => html.replaceAll(`src="${src}"`, `src="${src}" alt="${alt.replace(/"/g, '&quot;')}"`),
      post.content,
    )
  : post.content;
const contentOptimized = injectOptimizedUrls(contentWithAlts);
const contentWithBookmarks = await injectLocalizedBookmarks(contentOptimized, locale);
const contentWithAds = injectZoomIcons(contentWithBookmarks);
const blogPosting = buildBlogPostingSchema(post, canonical);
const sponsoredLabel = t("post.sponsored", locale);

const gaPageParams = {
  page_type: 'post',
  content_slug: post.slug,
  content_category: post.category,
  content_sub_category: post.sub_category,
  content_locale: locale,
  is_sponsored: post.is_sponsored,
};
---

<Layout
  title={`${post.title} | ${t("meta.siteName", locale)}`}
  description={post.description}
  canonical={canonical}
  path={path}
  locale={locale}
  ogImage={post.thumbnail}
  type="article"
  gaPageParams={gaPageParams}
  isMultilingual={post.is_multilingual}
>
  <Fragment slot="head">
    <link rel="preload" href={optimizedUrl(post.thumbnail)} as="image" type="image/webp" fetchpriority="high" />
    <BreadcrumbJsonLd items={breadcrumbs} />
    <BlogPostingJsonLd posting={blogPosting} />
  </Fragment>

  <div class="max-w-screen-xl mx-auto px-4 lg:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-[180px_1fr_300px] gap-0 lg:gap-8 min-h-screen">

      <LeftSidebar locale={locale} />

      <main class="min-w-0 py-6">

        {/* TODO: 애드센스 되돌리기 — <FixedAdsense variant="post-top" /> */}

        <article itemscope itemtype="https://schema.org/BlogPosting">

          <PostBadges
            isRecommended={post.is_recommended}
            label={sponsoredLabel}
          />

          <h1
            class="text-2xl sm:text-3xl font-bold text-gray-900 leading-tight mb-4"
            itemprop="headline"
          >
            {post.title}
          </h1>

          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500 mb-5">
            <time
              datetime={post.created_at}
              itemprop="datePublished"
              class="flex items-center gap-1"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <title>{t("a11y.calendar", locale)}</title>
                <desc>{t("a11y.calendar", locale)}</desc>
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
              </svg>
              {publishDate}
            </time>
            {post.is_sponsored && (
              <>
                <span aria-hidden="true" class="text-gray-300">|</span>
                <span class="text-gray-400">{t("post.sponsoredDisclosure", locale)}</span>
              </>
            )}
          </div>

          <div class="aspect-video w-full overflow-hidden mb-6 bg-gray-100 relative img-zoom-parent">
            <img
              src={optimizedUrl(post.thumbnail)}
              data-full={post.thumbnail}
              alt={post.thumbnail_alt ?? post.title}
              width="1280"
              height="720"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              class="w-full h-full object-cover cursor-pointer"
              itemprop="image"
              data-lightbox
            />
            <span class="img-zoom-hint" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
            </span>
          </div>

          {post.place_name && (
            <PlaceInfoCard
              categoryLabel={categoryLabel}
              subCategoryLabel={subCategoryLabel}
              placeName={post.place_name}
              translatedPlaceName={post.translated_place_name}
              address={post.address}
              translatedAddress={post.translated_address}
              pricePrefix={post.price_prefix}
              translatedPricePrefix={post.translated_price_prefix}
              price={post.price}
              description={post.description}
              locale={locale}
            />
          )}

          {!post.place_name && post.product_name && post.product_name.length > 0 && (
            <ProductInfoCard
              categoryLabel={categoryLabel}
              subCategoryLabel={subCategoryLabel}
              productNames={post.product_name}
              translatedProductNames={post.translated_product_name}
              purchaseSources={post.purchase_source}
              translatedPurchaseSources={post.translated_purchase_source}
              purchaseLinks={post.purchase_link}
              prices={post.price}
              pricePrefixes={post.price_prefix}
              translatedPricePrefixes={post.translated_price_prefix}
              description={post.description}
              locale={locale}
            />
          )}

          <div
            class="prose prose-gray max-w-none text-[16px] leading-[1.65]
                   prose-headings:font-bold prose-headings:text-gray-900
                   prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline
                   prose-img:shadow-sm
                   prose-blockquote:border-primary-400 prose-blockquote:text-gray-600"
            itemprop="articleBody"
            set:html={contentWithAds}
          />

        </article>

        <p class="text-sm text-gray-400 mt-6">
          * {locale === DEFAULT_LOCALE
            ? t("post.aiRefined", locale)
            : t("post.aiTranslated", locale)}
        </p>

        <NearbyPostList
          posts={nearbyLocalized}
          currentSlug={post.slug}
          categoryLabel={categoryLabel}
          subCategoryLabel={subCategoryLabel}
          moreLabel={t("post.more", locale)}
          subCategoryHref={subCategoryHref}
          locale={locale}
        />

        <div class="block lg:hidden mt-12">
          <SponsoredPostList
            locale={locale}
            posts={sponsoredLocalized}
            currentSlug={post.slug}
          />
        </div>

      </main>

      <RightSidebar
        locale={locale}
        sponsoredPosts={sponsoredLocalized}
        currentSlug={post.slug}
      />

    </div>
  </div>

  <script
    type="application/json"
    id="carousel-i18n"
    set:html={JSON.stringify({
      prev: t("a11y.carouselPrev", locale),
      next: t("a11y.carouselNext", locale),
    })}
  />

  <script>
    import { initAdTracker } from "@/shared/lib/analytics/ad-tracker";
    initAdTracker("post");

    document.querySelectorAll<HTMLElement>('[data-type="image-carousel"]').forEach((container) => {
      const imgs = Array.from(container.querySelectorAll<HTMLImageElement>(':scope > img'));
      if (imgs.length === 0) return;

      const viewport = document.createElement('div');
      viewport.className = 'carousel-viewport';

      imgs.forEach((img) => {
        const slide = document.createElement('div');
        slide.className = 'carousel-slide';
        const w = img.getAttribute('data-width') || '90%';
        const h = img.getAttribute('data-height') || 'auto';
        slide.style.flex = `0 0 ${w}`;
        img.style.height = h === 'auto' ? 'auto' : h;
        if (h !== 'auto') img.style.objectFit = 'cover';
        img.style.cursor = 'pointer';
        slide.appendChild(img);

        const hint = document.createElement('span');
        hint.className = 'img-zoom-hint';
        hint.setAttribute('aria-hidden', 'true');
        hint.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>';
        slide.appendChild(hint);

        viewport.appendChild(slide);
      });

      container.appendChild(viewport);

      if (imgs.length <= 1) return;

      let current = 0;
      const slides = Array.from(viewport.querySelectorAll<HTMLElement>('.carousel-slide'));

      const scrollTo = (index: number) => {
        const slide = slides[index];
        if (slide) {
          viewport.scrollTo({ left: slide.offsetLeft, behavior: 'smooth' });
          current = index;
        }
      };

      const i18nEl = document.getElementById('carousel-i18n');
      const i18n = i18nEl ? JSON.parse(i18nEl.textContent || '{}') : {};

      const createArrow = (direction: 'prev' | 'next') => {
        const label = direction === 'prev' ? (i18n.prev || 'Previous') : (i18n.next || 'Next');
        const btn = document.createElement('button');
        btn.className = `carousel-arrow carousel-arrow--${direction}`;
        btn.setAttribute('aria-label', label);
        const titleTag = `<title>${label}</title><desc>${label}</desc>`;
        btn.innerHTML = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${titleTag}<path d="${direction === 'prev' ? 'M15 18l-6-6 6-6' : 'M9 18l6-6-6-6'}"/></svg>`;
        btn.addEventListener('click', () => {
          const target = direction === 'prev'
            ? Math.max(0, current - 1)
            : Math.min(imgs.length - 1, current + 1);
          scrollTo(target);
        });
        return btn;
      };

      container.appendChild(createArrow('prev'));
      container.appendChild(createArrow('next'));

      viewport.addEventListener('scrollend', () => {
        let closestIdx = 0;
        let closestDist = Infinity;
        slides.forEach((s, idx) => {
          const dist = Math.abs(s.offsetLeft - viewport.scrollLeft);
          if (dist < closestDist) {
            closestDist = dist;
            closestIdx = idx;
          }
        });
        current = closestIdx;
      });
    });
  </script>
</Layout>
