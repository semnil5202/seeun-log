---
/** 인피드 광고 플레이스홀더. class prop으로 높이·grid span 등을 오버라이드한다. */

interface Props {
  class?: string;
  slotId?: string;
  position?: string;
}

const { class: className, slotId = "in_feed", position = "feed" } = Astro.props;
---

<div
  class:list={[
    "w-full bg-gray-100 flex items-center justify-center",
    className,
  ]}
  role="complementary"
  aria-label="Advertisement"
  data-ad-slot={slotId}
  data-ad-format="in_feed"
  data-ad-position={position}
>
  <span class="text-body2 text-gray-400 select-none">In-feed Adsense</span>
</div>
