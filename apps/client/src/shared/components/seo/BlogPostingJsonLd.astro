---
import JsonLd from "./JsonLd.astro";
import type { BlogPostingSchema } from "@/shared/types/seo";
import { SITE_NAME_KO } from "@eunminlog/config/site";

interface Props {
  posting: BlogPostingSchema;
}

const { posting } = Astro.props;
const site = Astro.site?.origin ?? "";

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: posting.title,
  description: posting.description,
  datePublished: posting.datePublished,
  dateModified: posting.dateModified,
  image: posting.image,
  url: `${site}${posting.url}`,
  author: {
    "@type": "Person",
    name: posting.authorName,
  },
  publisher: {
    "@type": "Organization",
    name: SITE_NAME_KO,
  },
};
---

<JsonLd schema={schema} />
