---
import "@/styles/global.css";
import OpenGraph from "@/shared/components/seo/OpenGraph.astro";
import Hreflang from "@/shared/components/seo/Hreflang.astro";
import type { Locale } from "@/shared/types/common";

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  locale: Locale;
  path: string;
  type?: "website" | "article";
  isMultilingual?: boolean;
}

const { title, description, canonical, ogImage, locale, path, type = "website", isMultilingual = true } = Astro.props;
const site = Astro.site?.origin ?? "";
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="naver-site-verification" content="a4c1a2f063a7e66e8bbc7ad2f097e3176693978e" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={`${site}${canonical}`} />
<OpenGraph
  title={title}
  description={description}
  url={`${site}${canonical}`}
  image={ogImage}
  locale={locale}
  type={type}
/>
<Hreflang path={path} isMultilingual={isMultilingual} />
<slot />
