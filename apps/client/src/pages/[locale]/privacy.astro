---
/** 다국어 개인정보처리방침 (/{locale}/privacy/) */

import Layout from "@/layouts/Layout.astro";
import { SITE_NAME_EN } from "@eunmin-log/config/site";
import { LOCALES, DEFAULT_LOCALE } from "@/shared/types/common";
import type { Locale } from "@/shared/types/common";
import { getPrivacyContent } from "@/features/privacy/content";

export const getStaticPaths = async () => {
  const nonDefaultLocales = LOCALES.filter((l) => l !== DEFAULT_LOCALE);

  return nonDefaultLocales.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
};

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const privacy = getPrivacyContent(locale);
const canonical = `/${locale}/privacy/`;
---

<Layout
  title={`${privacy.title} - ${SITE_NAME_EN}`}
  description={privacy.intro}
  canonical={canonical}
  path="/privacy/"
  locale={locale}
>
  <main class="mx-auto max-w-screen-xl grow px-4 lg:px-6 pt-10 pb-12">
    <h1 class="text-2xl font-bold text-gray-900">{privacy.title}</h1>
    <p class="mt-2 text-sm text-gray-400">{privacy.lastUpdated}</p>
    <p class="mt-6 text-gray-700 leading-relaxed">{privacy.intro}</p>

    {privacy.sections.map((section) => (
      <section class="mt-8">
        <h2 class="text-lg font-semibold text-gray-900">{section.heading}</h2>
        <p class="mt-2 text-gray-700 leading-relaxed whitespace-pre-line">{section.body}</p>
      </section>
    ))}
  </main>
</Layout>
