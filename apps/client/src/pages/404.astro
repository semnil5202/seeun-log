---
/** 404 Not Found 페이지 */

import Layout from "@/layouts/Layout.astro";
import { SITE_NAME_KO } from "@eunmin-log/config/site";
import { LOCALES, DEFAULT_LOCALE } from "@/shared/types/common";
import { t } from "@/shared/lib/i18n/translations";

const translations = Object.fromEntries(
  LOCALES.map((locale) => [
    locale,
    {
      title: t("error.title", locale),
      description: t("error.description", locale),
      goHome: t("error.goHome", locale),
    },
  ])
);
---

<Layout
  title={`페이지를 찾을 수 없습니다 - ${SITE_NAME_KO}`}
  description="요청하신 페이지를 찾을 수 없습니다."
  canonical="/404/"
  path="/404/"
  gaPageParams={{ page_type: "error", content_locale: "ko" }}
>
  <main class="flex grow flex-col items-center justify-center px-4 text-center">
    <p class="text-6xl font-bold text-primary">404</p>
    <h1 id="error-title" class="mt-4 text-2xl font-semibold text-gray-900">
      페이지를 찾을 수 없습니다.
    </h1>
    <p id="error-description" class="mt-2 text-gray-500">
      요청하신 페이지가 존재하지 않거나 이동되었을 수 있습니다.
    </p>
    <a
      id="error-home"
      href="/"
      class="mt-8 inline-block rounded-lg bg-primary px-6 py-3 text-sm font-medium text-white transition-colors hover:brightness-90"
    >
      메인페이지로 이동하기
    </a>
  </main>

  <script is:inline define:vars={{ translations, LOCALES, DEFAULT_LOCALE }}>
    const path = window.location.pathname;
    const segment = path.split("/")[1] || "";
    const locale = LOCALES.includes(segment) ? segment : DEFAULT_LOCALE;
    const tr = translations[locale] || translations[DEFAULT_LOCALE];

    document.getElementById("error-title").textContent = tr.title;
    document.getElementById("error-description").textContent = tr.description;

    const homeLink = document.getElementById("error-home");
    homeLink.textContent = tr.goHome;
    homeLink.href = locale === DEFAULT_LOCALE ? "/" : `/${locale}/`;

    document.documentElement.lang = locale;
  </script>
</Layout>
