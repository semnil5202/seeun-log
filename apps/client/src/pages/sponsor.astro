---
/** 한국어 협찬 문의 페이지 (/sponsor/) */

import Layout from "@/layouts/Layout.astro";
import JsonLd from "@/shared/components/seo/JsonLd.astro";
import { SITE_NAME_KO, SITE_URL } from "@eunminlog/config/site";
import { DEFAULT_LOCALE } from "@/shared/types/common";
import { getSponsorContent, buildMailtoHref } from "@/features/sponsor/content";

const locale = DEFAULT_LOCALE;
const sponsor = getSponsorContent(locale);
const mailtoHref = buildMailtoHref(sponsor);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: sponsor.meta.title,
  description: sponsor.meta.description,
  url: `${SITE_URL}/sponsor/`,
  inLanguage: "ko",
};
---

<Layout
  title={`${sponsor.meta.title} - ${SITE_NAME_KO}`}
  description={sponsor.meta.description}
  canonical="/sponsor/"
  path="/sponsor/"
  locale={locale}
>
  <Fragment slot="head">
    <JsonLd schema={jsonLd} />
  </Fragment>

  <main class="grow">
    <section class="bg-primary-50 py-16 lg:py-24">
      <div class="mx-auto max-w-screen-md px-4 lg:px-6 text-center">
        <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 whitespace-pre-line">
          {sponsor.hero.headline}
        </h1>
        <p class="mt-4 text-base lg:text-lg text-gray-600 leading-relaxed">
          {sponsor.hero.subtext}
        </p>
        <a
          href={mailtoHref}
          class="mt-8 inline-block bg-secondary-600 text-white px-8 py-3 text-sm font-semibold hover:bg-secondary-700 transition-colors"
        >
          {sponsor.hero.cta}
        </a>
      </div>
    </section>

    <section class="py-12 lg:py-16">
      <div class="mx-auto max-w-screen-md px-4 lg:px-6">
        <h2 class="text-2xl font-bold text-gray-900">{sponsor.blogIntro.heading}</h2>
        {sponsor.blogIntro.paragraphs.map((p) => (
          <p class="mt-4 text-gray-700 leading-relaxed">{p}</p>
        ))}
      </div>
    </section>

    <section class="bg-gray-50 py-12 lg:py-16">
      <div class="mx-auto max-w-screen-md px-4 lg:px-6">
        <h2 class="text-2xl font-bold text-gray-900">{sponsor.seoStrengths.heading}</h2>
        <p class="mt-2 text-gray-600">{sponsor.seoStrengths.subtext}</p>

        <div class="mt-8 border border-primary-200 bg-primary-50 p-6">
          <p class="text-lg font-semibold text-primary-700">
            {sponsor.seoStrengths.multilingual.heading}
          </p>
          <p class="mt-2 text-sm text-gray-600">
            {sponsor.seoStrengths.multilingual.description}
          </p>
        </div>

        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {sponsor.seoStrengths.features.map((feature) => (
            <div class="border border-gray-200 p-4">
              <p class="font-semibold text-gray-900">{feature.title}</p>
              <p class="mt-1 text-sm text-gray-600">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 lg:py-16">
      <div class="mx-auto max-w-screen-md px-4 lg:px-6 text-center">
        <h2 class="text-2xl font-bold text-gray-900">{sponsor.stats.heading}</h2>
        <div class="mt-8 grid grid-cols-2 gap-6 sm:grid-cols-4">
          {sponsor.stats.items.map((stat) => (
            <div>
              <p class="text-2xl lg:text-3xl font-bold text-primary-600">{stat.value}</p>
              <p class="mt-1 text-sm text-gray-500">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-gray-50 py-12 lg:py-16">
      <div class="mx-auto max-w-screen-md px-4 lg:px-6">
        <h2 class="text-2xl font-bold text-gray-900">{sponsor.collaboration.heading}</h2>
        <p class="mt-2 text-gray-600">{sponsor.collaboration.subtext}</p>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          {sponsor.collaboration.types.map((collab) => (
            <div class="border border-gray-200 bg-white p-6 text-center">
              <span class="text-3xl" aria-hidden="true">{collab.icon}</span>
              <p class="mt-3 font-semibold text-gray-900">{collab.title}</p>
              <p class="mt-2 text-sm text-gray-600">{collab.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 lg:py-20">
      <div class="mx-auto max-w-screen-md px-4 lg:px-6 text-center">
        <h2 class="text-2xl font-bold text-gray-900">{sponsor.cta.heading}</h2>
        <p class="mt-3 text-gray-600">{sponsor.cta.subtext}</p>
        <a
          href={mailtoHref}
          class="mt-8 inline-block bg-secondary-600 text-white px-10 py-4 text-base font-semibold hover:bg-secondary-700 transition-colors"
        >
          {sponsor.cta.buttonLabel}
        </a>
      </div>
    </section>
  </main>
</Layout>
